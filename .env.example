# ZELIX E-COMMERCE ENVIRONMENT VARIABLES TEMPLATE

# 1. Supabase Database Configuration
# Obtain these from Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# 2. Stripe Payment Integration Configuration
# Obtain these from Stripe Dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# 3. Stripe Webhook Secret Key
# Obtain this by running Stripe CLI locally: "stripe listen --forward-to localhost:3000/api/webhooks/stripe"
# Or from the Stripe Dashboard Webhooks setup under your endpoint settings.
# For mock checkout testing, you can leave these blank.
STRIPE_WEBHOOK_SECRET=whsec_...

# 4. Amazon SES / SMTP Configuration Settings
# (Primary email delivery method)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-aws-smtp-username-here
SMTP_PASSWORD=your-aws-smtp-password-here
SMTP_FROM="ZELIX Apparel <orders@yourdomain.com>"

# 5. Fallback SMTP Configuration Settings
# (Used if Amazon SES SMTP fails or is rejected)
FALLBACK_SMTP_HOST=smtp.gmail.com
FALLBACK_SMTP_PORT=587
FALLBACK_SMTP_USER=your-fallback-smtp-username-here
FALLBACK_SMTP_PASSWORD=your-fallback-smtp-password-here
FALLBACK_SMTP_FROM="ZELIX Backup <backup@yourdomain.com>"

# 6. Resend API Client Key
# (Alternative delivery fallback)
RESEND_API_KEY=re_your_api_key_here

# 7. Testing Configuration
# Set to true to disable live emails entirely and fall back to local console mock logging
DISABLE_EMAIL=false
